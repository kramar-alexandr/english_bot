[Unit]
Description=English Learning Telegram Bot
After=network.target mysql.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/english_bot
EnvironmentFile=/opt/english_bot/.env
ExecStart=/usr/bin/python3 /opt/english_bot/bot.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
